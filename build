#!/bin/bash
set -euo pipefail
IFS=$'\n\t'

# Set desired name via CLI argument, but default to ""
name="${1}"

# validate name: must be provided and not empty/whitespace-only
_raw_name="${1:-}"
# trim leading/trailing whitespace
name="$(printf '%s' "${_raw_name}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

if [ -z "${name}" ]; then
	printf '%s\n' "Error: Name cannot be empty. Usage: $(basename "$0") <name>" >&2
	exit 1
fi

echo "Creating distrobox"
distrobox assemble create --file "$name.ini"