#!/bin/bash
set -euo pipefail
IFS=$'\n\t'

INI_DIR="$HOME/distrobox-inis"

assemble_box() {
    local target_name="$1"
    local ini_path="$INI_DIR/$target_name.ini"

    if [[ -f "$ini_path" ]]; then
        echo "--- Creating/Replacing distrobox: $target_name ---"
        distrobox assemble create --replace --file "$ini_path"
    else
        echo "Error: File $ini_path not found." >&2
        return 1
    fi
}

if [ $# -eq 0 ]; then
    printf '%s\n' "Usage: $(basename "$0") <name> | --all" >&2
    exit 1
fi

if [[ "$1" == "--all" ]]; then
    echo "Processing all .ini files in $INI_DIR..."
    
    for file in "$INI_DIR"/*.ini; do
        [ -e "$file" ] || { echo "No .ini files found in $INI_DIR"; exit 1; }
        
        base_name=$(basename "$file" .ini)
        assemble_box "$base_name"
    done
else
    name="$(printf '%s' "$1" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    
    if [ -z "${name}" ]; then
        printf '%s\n' "Error: Name cannot be empty." >&2
        exit 1
    fi
    
    assemble_box "$name"
fi